"""
Environment configuration template.
Copy this to .env and fill in your values.
"""

# Environment
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_WORKERS=4
API_TIMEOUT=30

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/job_recommendation

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Model Configuration
MODEL_N_ESTIMATORS=100
MODEL_MAX_DEPTH=6
MODEL_LEARNING_RATE=0.1

# Features
USE_TFIDF=true
USE_EMBEDDINGS=true
USE_FUZZY_MATCHING=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Monitoring
ENABLE_DRIFT_DETECTION=true
DRIFT_THRESHOLD=0.1
METRICS_RETENTION_DAYS=30
ENABLE_PREDICTION_LOGGING=true

# Security
SECRET_KEY=your-secret-key-here
API_KEY_REQUIRED=false
CORS_ORIGINS=*

# Feature Flags
FF_BATCH_PREDICTIONS=true
FF_EXPLAINABILITY=true
FF_FEEDBACK_LOOP=true
FF_CACHING=true
FF_DRIFT_MONITORING=true

# Logging
LOG_LEVEL=INFO

# Validation
MIN_RESUME_LENGTH=50
MAX_RESUME_LENGTH=1000000
MIN_JOB_LENGTH=50
MAX_JOB_LENGTH=500000
